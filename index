<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Martin Faure — Développeur Web & Designer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg: #e8e4dc;
        --dark: #111;
        --mid: #555;
        --muted: rgba(17,17,17,0.4);
        --border: rgba(17,17,17,0.12);
      }

      body {
        background: var(--bg);
        color: var(--dark);
        font-family: "Inter", sans-serif;
        overflow-x: hidden;
        min-height: 100vh;
      }

      /* ── NAV ── */
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 32px;
        position: relative;
        z-index: 10;
      }

      .nav-left {
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.02em;
        color: var(--dark);
        opacity: 0.75;
      }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .nav-toggle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        border: 1.5px solid var(--dark);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 18px;
        line-height: 1;
        color: var(--dark);
        transition: background 0.2s, color 0.2s;
      }
      .nav-toggle:hover {
        background: var(--dark);
        color: var(--bg);
      }

      .nav-links {
        display: flex;
        gap: 2px;
        align-items: center;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--dark);
        font-size: 14px;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 999px;
        opacity: 0.5;
        transition: background 0.2s, color 0.2s, opacity 0.2s;
      }
      .nav-links a:hover {
        background: rgba(0,0,0,0.07);
        opacity: 1;
      }
      .nav-links a.active {
        background: var(--dark);
        color: var(--bg);
        opacity: 1;
      }

      /* ── HERO TITLE ── */
      .hero-title {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(80px, 13vw, 200px);
        line-height: 0.88;
        letter-spacing: -0.01em;
        padding: 0 18px;
        color: var(--dark);
        opacity: 0;
        animation: fadeDown 0.8s 0.05s ease forwards;
      }

      @keyframes fadeDown {
        from { opacity: 0; transform: translateY(-28px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeIn {
        from { opacity: 0; }
        to   { opacity: 1; }
      }

      /* ── MAIN GRID ── */
      .hero-body {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        padding: 40px 32px 0;
      }

      /* ── LEFT COLUMN ── */
      .hero-left {
        padding-top: 20px;
        display: flex;
        flex-direction: column;
        gap: 0;
        opacity: 0;
        animation: fadeUp 0.85s 0.2s ease forwards;
      }

      /* Eyebrow */
      .eyebrow {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 28px;
      }
      .eyebrow-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--dark);
        animation: pulse 2s ease infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
      }
      .eyebrow span {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--dark);
        opacity: 0.45;
      }

      /* Description */
      .hero-desc {
        font-size: 16px;
        line-height: 1.7;
        font-weight: 400;
        max-width: 400px;
        color: var(--dark);
        margin-bottom: 40px;
      }
      .hero-desc strong {
        font-weight: 700;
      }
      .hero-desc a {
        color: var(--dark);
        font-weight: 700;
        border-bottom: 2px solid var(--dark);
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .hero-desc a:hover { opacity: 0.6; }

      /* CTA row */
      .cta-row {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 52px;
        flex-wrap: wrap;
      }

      .btn-contact {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--dark);
        color: var(--bg);
        padding: 14px 28px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        letter-spacing: 0.01em;
        transition: opacity 0.2s, transform 0.2s;
      }
      .btn-contact:hover {
        opacity: 0.78;
        transform: scale(0.97);
      }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        color: var(--dark);
        padding: 14px 24px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: 1.5px solid rgba(17,17,17,0.22);
        letter-spacing: 0.01em;
        transition: border-color 0.2s, background 0.2s;
      }
      .btn-ghost:hover {
        border-color: var(--dark);
        background: rgba(17,17,17,0.04);
      }

      /* Stats */
      .stats-row {
        display: flex;
        gap: 0;
        border-top: 1px solid var(--border);
        padding-top: 28px;
      }
      .stat {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding-right: 20px;
        border-right: 1px solid var(--border);
      }
      .stat:last-child { border-right: none; padding-right: 0; padding-left: 20px; flex: unset; }
      .stat:first-child { padding-left: 0; }
      .stat-num {
        font-family: "Bebas Neue", sans-serif;
        font-size: 42px;
        line-height: 1;
        color: var(--dark);
        letter-spacing: 0.02em;
      }
      .stat-label {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
      }

      /* ── RIGHT COLUMN ── */
      .hero-right {
        position: relative;
        opacity: 0;
        animation: fadeUp 0.85s 0.35s ease forwards;
      }

      .hero-image-wrap {
        background: #1a1a1a;
        border-radius: 20px 20px 0 0;
        overflow: hidden;
        height: 520px;
        position: relative;
      }

      .hero-image-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }

      /* Image overlay gradient */
      .hero-image-wrap::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 120px;
        background: linear-gradient(transparent, rgba(26,26,26,0.5));
        pointer-events: none;
      }

      /* ── AVAIL BADGE ── */
      .avail-badge {
        position: absolute;
        bottom: 0;
        right: -28px;
        background: var(--bg);
        padding: 22px 32px;
        border-top: 3px solid var(--dark);
        min-width: 280px;
        opacity: 0;
        animation: fadeUp 0.9s 0.55s ease forwards;
      }

      .avail-badge .avail-top {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 6px;
      }
      .avail-badge .avail-dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: #3d9c3d;
        animation: pulse 2s ease infinite;
      }
      .avail-badge .label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--dark);
        opacity: 0.5;
      }
      .avail-badge .date {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(48px, 6vw, 76px);
        line-height: 1;
        color: var(--dark);
        letter-spacing: 0.02em;
      }
      .badge-underline {
        height: 3px;
        background: var(--dark);
        margin-top: 10px;
      }

      /* ── SKILLS STRIP ── */
      .skills-strip {
        padding: 48px 32px 0;
        opacity: 0;
        animation: fadeUp 0.85s 0.5s ease forwards;
      }

      .strip-label {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 16px;
      }

      .strip-inner {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .skill-chip {
        font-size: 12px;
        font-weight: 500;
        color: var(--dark);
        border: 1.5px solid var(--border);
        border-radius: 999px;
        padding: 6px 16px;
        letter-spacing: 0.03em;
        transition: border-color 0.2s, background 0.2s;
        cursor: default;
      }
      .skill-chip:hover {
        border-color: var(--dark);
        background: rgba(17,17,17,0.05);
      }

      /* ── FOOTER STRIP ── */
      .footer-strip {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 36px 32px 32px;
        margin-top: 48px;
        border-top: 1px solid var(--border);
        opacity: 0;
        animation: fadeIn 0.8s 0.7s ease forwards;
      }
      .footer-strip span {
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        letter-spacing: 0.06em;
      }
      .footer-strip a {
        color: var(--dark);
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.06em;
        opacity: 0.5;
        transition: opacity 0.2s;
      }
      .footer-strip a:hover { opacity: 1; }

      /* ══ RESPONSIVE ══ */
      @media (max-width: 900px) {
        .hero-body {
          grid-template-columns: 1fr;
          padding: 28px 24px 0;
          gap: 40px;
        }
        .hero-right { order: -1; }
        .hero-image-wrap { height: 360px; border-radius: 16px; }
        .avail-badge {
          right: 0;
          min-width: 200px;
          padding: 16px 20px;
        }
        .skills-strip { padding: 36px 24px 0; }
        .footer-strip { padding: 28px 24px 24px; }
        .stats-row { gap: 0; }
        .stat { padding-right: 16px; }
        .stat:last-child { padding-left: 16px; }
      }

      @media (max-width: 600px) {
        nav { padding: 14px 18px; }
        .nav-links { display: none; }
        .hero-title {
          font-size: clamp(52px, 16vw, 90px);
          padding: 0 12px;
        }
        .hero-body { padding: 18px 18px 0; gap: 28px; }
        .hero-image-wrap { height: 260px; border-radius: 12px; }
        .avail-badge {
          position: relative;
          right: auto; bottom: auto;
          border-top: 2px solid var(--dark);
          padding: 14px 16px;
          min-width: 0; width: 100%;
          animation: none; opacity: 1;
        }
        .avail-badge .date { font-size: clamp(32px, 10vw, 52px); }
        .hero-left {
          gap: 0;
          padding-top: 0;
          animation: none; opacity: 1;
        }
        .hero-title { animation: none; opacity: 1; }
        .hero-right { animation: none; opacity: 1; }
        .hero-desc { font-size: 14px; }
        .btn-contact { padding: 12px 22px; font-size: 13px; }
        .btn-ghost { padding: 12px 18px; font-size: 13px; }
        .cta-row { gap: 10px; }
        .skills-strip { padding: 28px 18px 0; }
        .footer-strip {
          padding: 24px 18px 20px;
          flex-direction: column;
          gap: 8px;
          text-align: center;
        }
        .stats-row {
          flex-wrap: wrap;
          gap: 20px;
        }
        .stat { border-right: none; padding: 0; }
        .stat:last-child { padding: 0; }
        .stat-num { font-size: 34px; }
      }
    </style>
  </head>
  <body>

    <nav>
      <div class="nav-left">Développeur Web &amp; Designer</div>
      <div class="nav-right">
        <button class="nav-toggle">—</button>
        <div class="nav-links">
          <a href="./index.html" class="active">Accueil</a>
          <a href="./projets.html">Projets</a>
          <a href="./design.html">Design</a>
          <a href="./apropos.html">A Propos</a>
          <a href="./contact.html">Contact</a>
        </div>
      </div>
    </nav>

    <div class="hero-title">MART/N FAURE</div>

    <div class="hero-body">

      <!-- LEFT -->
      <div class="hero-left">

        <div class="eyebrow">
          <div class="eyebrow-dot"></div>
          <span>Apprenti Développeur · Eden School</span>
        </div>

        <p class="hero-desc">
          Je maîtrise la création de sites web de <strong>A à Z</strong> — du
          back-end à l'interface. Ma particularité&nbsp;: une forte passion pour
          le <strong>design</strong> que je cultive en autodidacte pour donner
          une identité visuelle unique à chaque projet.
        </p>

        <div class="cta-row">
          <a href="./contact.html" class="btn-contact">Me Contacter ↗</a>
          <a href="./projets.html" class="btn-ghost">Voir mes projets</a>
        </div>

        <div class="stats-row">
          <div class="stat">
            <span class="stat-num">3+</span>
            <span class="stat-label">Ans d'exp.</span>
          </div>
          <div class="stat" style="padding-left:20px;">
            <span class="stat-num">10+</span>
            <span class="stat-label">Projets</span>
          </div>
          <div class="stat last">
            <span class="stat-num">8</span>
            <span class="stat-label">Technos</span>
          </div>
        </div>

      </div>

      <!-- RIGHT -->
      <div class="hero-right">
        <div class="hero-image-wrap">
          <img
            src="data:image/png;base64,"
            alt="Martin Faure"
          />
        </div>

        <div class="avail-badge">
          <div class="avail-top">
            <div class="avail-dot"></div>
            <div class="label">Disponible pour une alternance</div>
          </div>
          <div class="date">SEPT'26</div>
          <div class="badge-underline"></div>
        </div>
      </div>

    </div>

    <!-- SKILLS STRIP -->
    <div class="skills-strip">
      <div class="strip-label">Stack technique</div>
      <div class="strip-inner">
        <span class="skill-chip">HTML</span>
        <span class="skill-chip">CSS</span>
        <span class="skill-chip">JavaScript</span>
        <span class="skill-chip">PHP</span>
        <span class="skill-chip">MySQL</span>
        <span class="skill-chip">Node.js</span>
        <span class="skill-chip">TailwindCSS</span>
        <span class="skill-chip">Git</span>
        <span class="skill-chip">Docker</span>
        <span class="skill-chip">Figma</span>
      </div>
    </div>

    <!-- FOOTER STRIP -->
    <div class="footer-strip">
      <span>© Martin Faure 2025</span>
      <span>Chambéry, France</span>
      <a href="./contact.html">faure.martin2705@gmail.com ↗</a>
    </div>

    <script>
      // Mobile hamburger
      const toggle = document.querySelector(".nav-toggle");
      const links = document.querySelector(".nav-links");
      if (toggle && links) {
        toggle.addEventListener("click", () => {
          const open = links.style.display === "flex";
          links.style.display = open ? "" : "flex";
          links.style.flexDirection = "column";
          links.style.position = "fixed";
          links.style.top = "60px";
          links.style.right = "18px";
          links.style.background = "var(--bg, #e8e4dc)";
          links.style.padding = "16px";
          links.style.borderRadius = "12px";
          links.style.border = "1px solid rgba(17,17,17,0.12)";
          links.style.zIndex = "999";
          if (open) links.removeAttribute("style");
        });
      }
    </script>
  </body>
</html>